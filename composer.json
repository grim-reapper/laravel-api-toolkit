{
    "name": "imran/laravel-api-toolkit",
    "description": "Standardized JSON API responses and an automatic, environment-aware exception handler for Laravel APIs.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "api",
        "json",
        "response",
        "exception-handler",
        "validation",
        "rest"
    ],
    "homepage": "https://github.com/grim-reapper/laravel-api-toolkit",
    "support": {
        "issues": "https://github.com/grim-reapper/laravel-api-toolkit/issues",
        "source": "https://github.com/grim-reapper/laravel-api-toolkit"
    },
    "authors": [
        {
            "name": "Imran",
            "email": "imran.ali125@yahoo.com"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4",
        "illuminate/auth": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/validation": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "mockery/mockery": "^1.5|^2.0",
        "laravel/framework": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Imran\\ApiToolkit\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Imran\\ApiToolkit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Imran\\ApiToolkit\\ApiToolkitServiceProvider"
            ],
            "aliases": {
                "ApiResponse": "Imran\\ApiToolkit\\Facades\\ApiResponse"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --no-coverage"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
